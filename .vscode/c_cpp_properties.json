{
  "version": 4,
  "configurations": [
    {
      "name": "Win32-MFC",
      "intelliSenseMode": "windows-msvc-x64",
      "compilerPath": "cl.exe",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/RemoteCtrl/RemoteCtrl",
        "${workspaceFolder}/RemoteClient/RemoteClient",
        "C:/Program Files (x86)/Microsoft Visual Studio/2019/*/VC/Tools/MSVC/*/include",
        "C:/Program Files (x86)/Microsoft Visual Studio/2019/*/VC/Tools/MSVC/*/atlmfc/include",
        "C:/Program Files/Microsoft Visual Studio/2022/*/VC/Tools/MSVC/*/include",
        "C:/Program Files/Microsoft Visual Studio/2022/*/VC/Tools/MSVC/*/atlmfc/include",
        "C:/Program Files (x86)/Windows Kits/10/Include/*/ucrt",
        "C:/Program Files (x86)/Windows Kits/10/Include/*/um",
        "C:/Program Files (x86)/Windows Kits/10/Include/*/shared",
        "C:/Program Files (x86)/Windows Kits/10/Include/*/winrt",
        "C:/Program Files (x86)/Windows Kits/10/Include/*/cppwinrt"
      ],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "WIN32",
        "_WINDOWS",
        "_AFXDLL"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "C:/Program Files (x86)/Microsoft Visual Studio/2019/*/VC/Tools/MSVC/*/include",
          "C:/Program Files (x86)/Microsoft Visual Studio/2019/*/VC/Tools/MSVC/*/atlmfc/include",
          "C:/Program Files/Microsoft Visual Studio/2022/*/VC/Tools/MSVC/*/include",
          "C:/Program Files/Microsoft Visual Studio/2022/*/VC/Tools/MSVC/*/atlmfc/include",
          "C:/Program Files (x86)/Windows Kits/10/Include/*/ucrt",
          "C:/Program Files (x86)/Windows Kits/10/Include/*/um",
          "C:/Program Files (x86)/Windows Kits/10/Include/*/shared"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
